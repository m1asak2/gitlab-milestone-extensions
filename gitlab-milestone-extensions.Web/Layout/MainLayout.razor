@inherits LayoutComponentBase
@implements IDisposable
@inject DashboardApiClient ApiClient
@inject NavigationManager NavigationManager
@inject MilestoneSelectionState SelectionState
@inject PrivateTokenStorage PrivateTokenStorage

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">GitLab Milestone Dashboard</MudText>
        <MudSpacer />
        @if (_currentGitLabUser is not null)
        {
            <div class="d-flex align-center mr-3">
                <img src="images/gitlab-mark.svg" alt="GitLab" style="width: 20px; height: 20px;" />
                <MudText Typo="Typo.body2" Class="ml-2">@_currentGitLabUser.Name</MudText>
            </div>
        }
        @if (SelectionState.HasPrivateToken && !_isTokenEditorVisible)
        {
            <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="ShowTokenEditor">
                Change Token
            </MudButton>
        }
        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Refresh" Href="@NavigationManager.Uri">
            Refresh
        </MudButton>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
            <MudPaper Class="pa-4 mb-4">
                @if (_isTokenEditorVisible)
                {
                    <MudGrid Class="mb-4">
                        <MudItem xs="12" md="8">
                            <label class="selector-label" for="private-token-input">GitLab Private Token</label>
                            <input id="private-token-input"
                                   class="selector-input"
                                   type="password"
                                   value="@(_privateTokenInput ?? string.Empty)"
                                   @oninput="@(args => _privateTokenInput = args.Value?.ToString())"
                                   placeholder="GitLab の Private Token を入力" />
                        </MudItem>
                        <MudItem xs="12" md="4" Class="d-flex align-end">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="ApplyPrivateTokenAsync"
                                       Disabled="@_isLoadingSelectors">
                                Apply Token
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                }

                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <label class="selector-label" for="group-select">Group</label>
                        <select id="group-select"
                                class="selector-input"
                                value="@(_selectedGroupId?.ToString() ?? string.Empty)"
                                @onchange="OnGroupChanged"
                                disabled="@(_isLoadingSelectors || !SelectionState.HasPrivateToken)">
                            <option value="">Select Group</option>
                            @foreach (var group in _groups)
                            {
                                <option value="@group.GroupId">@group.GroupName</option>
                            }
                        </select>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <label class="selector-label" for="member-select">Member</label>
                        <select id="member-select"
                                class="selector-input"
                                value="@(_selectedMemberId?.ToString() ?? string.Empty)"
                                @onchange="OnMemberChanged"
                                disabled="@(_isLoadingSelectors || !SelectionState.HasPrivateToken)">
                            <option value="">Select Member</option>
                            @foreach (var member in _members)
                            {
                                <option value="@member.MemberId">@member.MemberName</option>
                            }
                        </select>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <label class="selector-label" for="project-select">Project</label>
                        <select id="project-select"
                                class="selector-input"
                                value="@(_selectedProjectId?.ToString() ?? string.Empty)"
                                @onchange="OnProjectChanged"
                                disabled="@(_isLoadingSelectors || !SelectionState.HasPrivateToken)">
                            <option value="">Select Project</option>
                            @foreach (var project in _projects)
                            {
                                <option value="@project.ProjectId">@project.ProjectName</option>
                            }
                        </select>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <label class="selector-label" for="milestone-select">Milestone</label>
                        <select id="milestone-select"
                                class="selector-input"
                                value="@(_selectedMilestoneId?.ToString() ?? string.Empty)"
                                @onchange="OnMilestoneChanged"
                                disabled="@(_isLoadingSelectors || !SelectionState.HasPrivateToken)">
                            <option value="">Select Milestone</option>
                            @foreach (var milestone in _milestones)
                            {
                                <option value="@milestone.MilestoneId">@milestone.MilestoneTitle</option>
                            }
                        </select>
                    </MudItem>
                </MudGrid>

                @if (_isTokenEditorVisible)
                {
                    <MudAlert Class="mt-3" Severity="Severity.Info">
                        GitLab の参照が必要なときだけ Private Token を入力してください。入力後はブラウザに保存し、次回は入力欄を非表示にします。
                    </MudAlert>
                }

                @if (!string.IsNullOrWhiteSpace(_selectorError))
                {
                    <MudAlert Class="mt-3" Severity="Severity.Error">@_selectorError</MudAlert>
                }
            </MudPaper>

            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _isLoadingSelectors;
    private bool _isTokenEditorVisible = true;
    private bool _isApplyingSelectionFromUrl;
    private bool _isUpdatingUrlFromSelection;
    private string? _selectorError;
    private string? _privateTokenInput;
    private GitLabCurrentUserViewModel? _currentGitLabUser;

    private int? _selectedGroupId;
    private int? _selectedMemberId;
    private int? _selectedProjectId;
    private int? _selectedMilestoneId;

    private IReadOnlyList<SelectionGroupViewModel> _groups = [];
    private IReadOnlyList<SelectionMemberViewModel> _members = [];
    private IReadOnlyList<SelectionProjectViewModel> _projects = [];
    private IReadOnlyList<SelectionMilestoneViewModel> _milestones = [];

    protected override async Task OnInitializedAsync()
    {
        SelectionState.Changed += OnSelectionStateChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
        ApplySelectionFromUrl(NavigationManager.Uri);
        var rememberedToken = await PrivateTokenStorage.GetAsync();
        _privateTokenInput = rememberedToken;
        await InitializeTokenAsync(rememberedToken, saveIfValid: false);
    }

    public void Dispose()
    {
        SelectionState.Changed -= OnSelectionStateChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private async Task OnGroupChanged(ChangeEventArgs args)
    {
        var value = ParseNullableInt(args);
        _selectedGroupId = value;
        SelectionState.SetGroup(value);
        await LoadSelectionOptionsAsync();
    }

    private async Task ApplyPrivateTokenAsync()
    {
        await InitializeTokenAsync(_privateTokenInput, saveIfValid: true);
    }

    private void ShowTokenEditor()
    {
        _privateTokenInput = SelectionState.PrivateToken;
        _isTokenEditorVisible = true;
    }

    private async Task OnMemberChanged(ChangeEventArgs args)
    {
        var value = ParseNullableInt(args);
        _selectedMemberId = value;
        SelectionState.SetMember(value);
        await LoadSelectionOptionsAsync();
    }

    private async Task OnProjectChanged(ChangeEventArgs args)
    {
        var value = ParseNullableInt(args);
        _selectedProjectId = value;
        SelectionState.SetProject(value);
        await LoadSelectionOptionsAsync();
    }

    private Task OnMilestoneChanged(ChangeEventArgs args)
    {
        var value = ParseNullableInt(args);
        _selectedMilestoneId = value;
        SelectionState.SetMilestone(value);
        return LoadSelectionOptionsAsync();
    }

    private void OnSelectionStateChanged()
    {
        _privateTokenInput = SelectionState.PrivateToken;
        _selectedGroupId = SelectionState.SelectedGroupId;
        _selectedMemberId = SelectionState.SelectedMemberId;
        _selectedProjectId = SelectionState.SelectedProjectId;
        _selectedMilestoneId = SelectionState.SelectedMilestoneId;
        if (!_isApplyingSelectionFromUrl)
        {
            SyncUrlWithSelection();
        }

        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        if (_isUpdatingUrlFromSelection)
        {
            return;
        }

        ApplySelectionFromUrl(args.Location);
        _ = InvokeAsync(async () =>
        {
            if (SelectionState.HasPrivateToken)
            {
                await LoadSelectionOptionsAsync();
            }

            StateHasChanged();
        });
    }

    private async Task LoadSelectionOptionsAsync()
    {
        if (!SelectionState.HasPrivateToken)
        {
            _isLoadingSelectors = false;
            _selectorError = null;
            _isTokenEditorVisible = true;
            _currentGitLabUser = null;
            _groups = [];
            _members = [];
            _projects = [];
            _milestones = [];
            _selectedGroupId = null;
            _selectedMemberId = null;
            _selectedProjectId = null;
            _selectedMilestoneId = null;
            return;
        }

        _isLoadingSelectors = true;
        _selectorError = null;

        try
        {
            var options = await ApiClient.GetSelectionOptionsAsync(
                SelectionState.SelectedGroupId,
                SelectionState.SelectedMemberId,
                SelectionState.SelectedProjectId,
                SelectionState.SelectedMilestoneId);

            _groups = options.Groups;
            _members = options.Members;
            _projects = options.Projects;
            _milestones = options.Milestones;

            var selectionAdjusted = false;
            if (_selectedGroupId.HasValue && !_groups.Any(x => x.GroupId == _selectedGroupId.Value))
            {
                _selectedGroupId = null;
                SelectionState.SetGroup(null);
                selectionAdjusted = true;
            }

            if (_selectedMemberId.HasValue && !_members.Any(x => x.MemberId == _selectedMemberId.Value))
            {
                _selectedMemberId = null;
                SelectionState.SetMember(null);
                selectionAdjusted = true;
            }

            if (_selectedProjectId.HasValue && !_projects.Any(x => x.ProjectId == _selectedProjectId.Value))
            {
                _selectedProjectId = null;
                SelectionState.SetProject(null);
                selectionAdjusted = true;
            }

            if (_selectedMilestoneId.HasValue && !_milestones.Any(x => x.MilestoneId == _selectedMilestoneId.Value))
            {
                _selectedMilestoneId = null;
                SelectionState.SetMilestone(null);
                selectionAdjusted = true;
            }

            if (selectionAdjusted)
            {
                options = await ApiClient.GetSelectionOptionsAsync(
                    SelectionState.SelectedGroupId,
                    SelectionState.SelectedMemberId,
                    SelectionState.SelectedProjectId,
                    SelectionState.SelectedMilestoneId);

                _groups = options.Groups;
                _members = options.Members;
                _projects = options.Projects;
                _milestones = options.Milestones;
            }

            _selectedGroupId = SelectionState.SelectedGroupId;
            _selectedMemberId = SelectionState.SelectedMemberId;
            _selectedProjectId = SelectionState.SelectedProjectId;
            _selectedMilestoneId = SelectionState.SelectedMilestoneId;
        }
        catch (Exception ex)
        {
            _selectorError = ex.Message;
        }
        finally
        {
            _isLoadingSelectors = false;
        }
    }

    private async Task InitializeTokenAsync(string? token, bool saveIfValid)
    {
        _selectorError = null;
        _currentGitLabUser = null;
        SelectionState.SetPrivateToken(token);
        _privateTokenInput = SelectionState.PrivateToken;

        if (!SelectionState.HasPrivateToken)
        {
            await PrivateTokenStorage.RemoveAsync();
            _isTokenEditorVisible = true;
            await LoadSelectionOptionsAsync();
            return;
        }

        try
        {
            _currentGitLabUser = await ApiClient.GetCurrentUserAsync()
                ?? throw new InvalidOperationException("GitLab user could not be resolved from the provided token.");

            await LoadSelectionOptionsAsync();
            _isTokenEditorVisible = false;

            if (saveIfValid)
            {
                await PrivateTokenStorage.SetAsync(SelectionState.PrivateToken!);
            }
        }
        catch (Exception ex)
        {
            _selectorError = ex.Message;
            _currentGitLabUser = null;
            _isTokenEditorVisible = true;
            _privateTokenInput = token;
            SelectionState.SetPrivateToken(null);
            _groups = [];
            _members = [];
            _projects = [];
            _milestones = [];
            await PrivateTokenStorage.RemoveAsync();
        }
    }

    private void ApplySelectionFromUrl(string uriString)
    {
        var uri = NavigationManager.ToAbsoluteUri(uriString);
        var query = ParseQuery(uri.Query);
        var groupId = ParseNullableInt(query, "groupId");
        var memberId = ParseNullableInt(query, "memberId");
        var projectId = ParseNullableInt(query, "projectId");
        var milestoneId = ParseNullableInt(query, "milestoneId");

        _isApplyingSelectionFromUrl = true;
        try
        {
            SelectionState.SetSelection(groupId, memberId, projectId, milestoneId);
        }
        finally
        {
            _isApplyingSelectionFromUrl = false;
        }
    }

    private void SyncUrlWithSelection()
    {
        var currentUri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var path = currentUri.GetLeftPart(UriPartial.Path);
        var query = new Dictionary<string, string>();

        if (SelectionState.SelectedGroupId.HasValue)
        {
            query["groupId"] = SelectionState.SelectedGroupId.Value.ToString();
        }

        if (SelectionState.SelectedMemberId.HasValue)
        {
            query["memberId"] = SelectionState.SelectedMemberId.Value.ToString();
        }

        if (SelectionState.SelectedProjectId.HasValue)
        {
            query["projectId"] = SelectionState.SelectedProjectId.Value.ToString();
        }

        if (SelectionState.SelectedMilestoneId.HasValue)
        {
            query["milestoneId"] = SelectionState.SelectedMilestoneId.Value.ToString();
        }

        var targetUri = query.Count == 0
            ? path
            : $"{path}?{string.Join("&", query.Select(kvp => $"{Uri.EscapeDataString(kvp.Key)}={Uri.EscapeDataString(kvp.Value)}"))}";

        if (string.Equals(targetUri, NavigationManager.Uri, StringComparison.Ordinal))
        {
            return;
        }

        _isUpdatingUrlFromSelection = true;
        try
        {
            NavigationManager.NavigateTo(targetUri, replace: true);
        }
        finally
        {
            _isUpdatingUrlFromSelection = false;
        }
    }

    private static int? ParseNullableInt(ChangeEventArgs args)
    {
        var raw = args.Value?.ToString();
        return int.TryParse(raw, out var value) ? value : null;
    }

    private static Dictionary<string, string> ParseQuery(string queryString)
    {
        var query = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(queryString))
        {
            return query;
        }

        foreach (var segment in queryString.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = segment.Split('=', 2);
            var key = Uri.UnescapeDataString(parts[0]);
            var value = parts.Length > 1 ? Uri.UnescapeDataString(parts[1]) : string.Empty;
            query[key] = value;
        }

        return query;
    }

    private static int? ParseNullableInt(Dictionary<string, string> query, string key)
    {
        return query.TryGetValue(key, out var value) && int.TryParse(value, out var parsed)
            ? parsed
            : null;
    }
}
