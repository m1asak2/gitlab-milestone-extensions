@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">GitLab Milestone Dashboard</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Refresh" Href="/">
            Refresh
        </MudButton>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
