@page "/"
@page "/dashboard"
@inject DashboardApiClient ApiClient

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
}
else
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Total Issues</MudText>
                <MudText Typo="Typo.h5">@_summary?.TotalIssues</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Open Issues</MudText>
                <MudText Typo="Typo.h5">@_summary?.OpenIssues</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Closed Issues</MudText>
                <MudText Typo="Typo.h5">@_summary?.ClosedIssues</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Overdue Issues</MudText>
                <MudText Typo="Typo.h5">@_summary?.OverdueIssues</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTabs>
        <MudTabPanel Text="Issues">
            <MudGrid Class="mb-3">
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="string"
                                     Label="Project"
                                     @bind-Value="_projectFilter"
                                     SearchFunc="SearchProjectOptions"
                                     MinCharacters="0"
                                     OpenOnFocus="true"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="false"
                                     CoerceValue="false">
                        <ItemTemplate Context="item">
                            <span style="color:#1f2937">@item</span>
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="string"
                                     Label="Milestone"
                                     @bind-Value="_milestoneFilter"
                                     SearchFunc="SearchMilestoneOptions"
                                     MinCharacters="0"
                                     OpenOnFocus="true"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="false"
                                     CoerceValue="false">
                        <ItemTemplate Context="item">
                            <span style="color:#1f2937">@item</span>
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="string"
                                     Label="Assignee"
                                     @bind-Value="_assigneeFilter"
                                     SearchFunc="SearchAssigneeOptions"
                                     MinCharacters="0"
                                     OpenOnFocus="true"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="false"
                                     CoerceValue="false">
                        <ItemTemplate Context="item">
                            <span style="color:#1f2937">@item</span>
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="string"
                                     Label="State"
                                     @bind-Value="_stateFilter"
                                     SearchFunc="SearchStateOptions"
                                     MinCharacters="0"
                                     OpenOnFocus="true"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="false"
                                     CoerceValue="false">
                        <ItemTemplate Context="item">
                            <span style="color:#1f2937">@item</span>
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudItem>
            </MudGrid>

            <MudTable Items="FilteredIssues">
                <HeaderContent>
                    <MudTh>Id</MudTh>
                    <MudTh>Title</MudTh>
                    <MudTh>Project</MudTh>
                    <MudTh>Assignee</MudTh>
                    <MudTh>State</MudTh>
                    <MudTh>Milestone</MudTh>
                    <MudTh>Estimate</MudTh>
                    <MudTh>Actual</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Id">@context.Id</MudTd>
                    <MudTd DataLabel="Title">@context.Title</MudTd>
                    <MudTd DataLabel="Project">@context.ProjectName</MudTd>
                    <MudTd DataLabel="Assignee">@context.Assignee</MudTd>
                    <MudTd DataLabel="State">@context.State</MudTd>
                    <MudTd DataLabel="Milestone">@context.Milestone</MudTd>
                    <MudTd DataLabel="Estimate">@FormatIssueDuration(context.HumanTimeEstimate, context.TimeEstimateSeconds)</MudTd>
                    <MudTd DataLabel="Actual">@FormatIssueDuration(context.HumanTotalTimeSpent, context.TotalTimeSpentSeconds)</MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>
        <MudTabPanel Text="Milestones">
            <MudTable Items="_milestones">
                <HeaderContent>
                    <MudTh>Title</MudTh>
                    <MudTh>Project</MudTh>
                    <MudTh>Scope</MudTh>
                    <MudTh>Start</MudTh>
                    <MudTh>Due</MudTh>
                    <MudTh>Estimate</MudTh>
                    <MudTh>Actual</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Title">@context.Title</MudTd>
                    <MudTd DataLabel="Project">@context.ProjectName</MudTd>
                    <MudTd DataLabel="Scope">@context.Scope</MudTd>
                    <MudTd DataLabel="Start">@context.StartDate?.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd DataLabel="Due">@context.DueDate?.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd DataLabel="Estimate">@FormatSeconds(context.TimeEstimateSeconds)</MudTd>
                    <MudTd DataLabel="Actual">@FormatSeconds(context.TotalTimeSpentSeconds)</MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>
        <MudTabPanel Text="Gantt">
            <MudGrid Class="mb-3">
                <MudItem xs="12" sm="6" md="4">
                    <MudAutocomplete T="string"
                               Label="Milestone Filter"
                               @bind-Value="_ganttMilestoneFilter"
                               SearchFunc="SearchGanttMilestoneOptions"
                               MinCharacters="0"
                               OpenOnFocus="true"
                               Clearable="true"
                               ResetValueOnEmptyText="true"
                               CoerceText="false"
                               CoerceValue="false">
                        <ItemTemplate Context="item">
                            <span style="color:#1f2937">@item</span>
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudItem>
            </MudGrid>

            <MudTable Items="FilteredGanttItems">
                <HeaderContent>
                    <MudTh>Title</MudTh>
                    <MudTh>Mode</MudTh>
                    <MudTh>Owner</MudTh>
                    <MudTh>Start</MudTh>
                    <MudTh>End</MudTh>
                    <MudTh>Progress</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Title">@context.Title</MudTd>
                    <MudTd DataLabel="Mode">@context.ViewMode</MudTd>
                    <MudTd DataLabel="Owner">@context.Owner</MudTd>
                    <MudTd DataLabel="Start">@context.StartDate.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd DataLabel="End">@context.EndDate.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd DataLabel="Progress">
                        <MudProgressLinear Color="Color.Secondary" Value="@context.Progress" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>
    </MudTabs>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private SummaryViewModel? _summary;
    private IReadOnlyList<IssueViewModel> _issues = [];
    private IReadOnlyList<MilestoneViewModel> _milestones = [];
    private IReadOnlyList<GanttItemViewModel> _ganttItems = [];
    private string? _projectFilter;
    private string? _milestoneFilter;
    private string? _assigneeFilter;
    private string? _stateFilter;
    private string? _ganttMilestoneFilter;
    private IReadOnlyList<string> ProjectFilterOptions { get; set; } = [];
    private IReadOnlyList<string> MilestoneFilterOptions { get; set; } = [];
    private IReadOnlyList<string> AssigneeFilterOptions { get; set; } = [];
    private IReadOnlyList<string> StateFilterOptions { get; set; } = [];
    private IReadOnlyList<string> GanttMilestoneFilterOptions { get; set; } = [];

    private IReadOnlyList<IssueViewModel> FilteredIssues =>
        _issues.Where(i =>
                (string.IsNullOrWhiteSpace(_projectFilter) || i.ProjectName.Equals(_projectFilter, StringComparison.OrdinalIgnoreCase)) &&
                (string.IsNullOrWhiteSpace(_milestoneFilter) || i.Milestone.Equals(_milestoneFilter, StringComparison.OrdinalIgnoreCase)) &&
                (string.IsNullOrWhiteSpace(_assigneeFilter) || i.Assignee.Equals(_assigneeFilter, StringComparison.OrdinalIgnoreCase)) &&
                (string.IsNullOrWhiteSpace(_stateFilter) || i.State.Equals(_stateFilter, StringComparison.OrdinalIgnoreCase)))
            .ToList();

    private IReadOnlyList<GanttItemViewModel> FilteredGanttItems =>
        _ganttItems.Where(i =>
                string.IsNullOrWhiteSpace(_ganttMilestoneFilter) ||
                (!string.IsNullOrWhiteSpace(i.MilestoneTitle) &&
                 i.MilestoneTitle.Equals(_ganttMilestoneFilter, StringComparison.OrdinalIgnoreCase)))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var dashboardData = await ApiClient.GetDashboardDataAsync();
            _summary = dashboardData.Summary;
            _issues = dashboardData.Issues;
            _milestones = dashboardData.Milestones;
            _ganttItems = dashboardData.GanttItems;
            BuildFilterOptions();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BuildFilterOptions()
    {
        ProjectFilterOptions = BuildOptions(_issues.Select(i => i.ProjectName));
        MilestoneFilterOptions = BuildOptions(_issues.Select(i => i.Milestone));
        AssigneeFilterOptions = BuildOptions(_issues.Select(i => i.Assignee));
        StateFilterOptions = BuildOptions(_issues.Select(i => i.State));
        GanttMilestoneFilterOptions = BuildOptions(_ganttItems
            .Select(i => i.MilestoneTitle ?? string.Empty));
    }

    private static IReadOnlyList<string> BuildOptions(IEnumerable<string> values)
    {
        return values
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(v => v)
            .ToList();
    }

    private Task<IEnumerable<string>> SearchProjectOptions(string? value, CancellationToken cancellationToken) =>
        SearchOptions(ProjectFilterOptions, value);

    private Task<IEnumerable<string>> SearchMilestoneOptions(string? value, CancellationToken cancellationToken) =>
        SearchOptions(MilestoneFilterOptions, value);

    private Task<IEnumerable<string>> SearchAssigneeOptions(string? value, CancellationToken cancellationToken) =>
        SearchOptions(AssigneeFilterOptions, value);

    private Task<IEnumerable<string>> SearchStateOptions(string? value, CancellationToken cancellationToken) =>
        SearchOptions(StateFilterOptions, value);

    private Task<IEnumerable<string>> SearchGanttMilestoneOptions(string? value, CancellationToken cancellationToken) =>
        SearchOptions(GanttMilestoneFilterOptions, value);

    private static Task<IEnumerable<string>> SearchOptions(IEnumerable<string> source, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult(source);
        }

        var results = source.Where(x => x.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private static string FormatIssueDuration(string? humanReadable, int seconds)
    {
        if (!string.IsNullOrWhiteSpace(humanReadable))
        {
            return humanReadable;
        }

        return FormatSeconds(seconds);
    }

    private static string FormatSeconds(int seconds)
    {
        if (seconds <= 0)
        {
            return "0m";
        }

        var span = TimeSpan.FromSeconds(seconds);
        var days = (int)span.TotalDays;
        var hours = span.Hours;
        var minutes = span.Minutes;

        if (days > 0)
        {
            return $"{days}d {hours}h";
        }

        if (hours > 0)
        {
            return $"{hours}h {minutes}m";
        }

        return $"{minutes}m";
    }
}
