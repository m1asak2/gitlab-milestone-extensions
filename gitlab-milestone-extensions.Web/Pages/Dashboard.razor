@page "/"
@page "/dashboard"
@implements IDisposable
@inject DashboardApiClient ApiClient
@inject MilestoneSelectionState SelectionState

<PageTitle>@(_dashboard?.MilestoneTitle ?? "Dashboard")</PageTitle>

@if (_dashboard is { MilestoneTitle: { Length: > 0 } } dashboard)
{
    @if (!string.IsNullOrWhiteSpace(dashboard.MilestoneWebUrl))
    {
        <MudLink Href="@dashboard.MilestoneWebUrl" Target="_blank" Underline="Underline.Always" Color="Color.Primary" Class="d-inline-block mb-4">
            <MudText Typo="Typo.h4">@dashboard.MilestoneTitle</MudText>
        </MudLink>
    }
    else
    {
        <MudText Typo="Typo.h4" Class="mb-4">@dashboard.MilestoneTitle</MudText>
    }
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>
}

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
}
else if (!SelectionState.HasPrivateToken)
{
    <MudAlert Severity="Severity.Info">GitLab のデータを表示するには、画面上部に Private Token を入力してください。</MudAlert>
}
else if (SelectionState.SelectedMilestoneId is null)
{
    <MudAlert Severity="Severity.Info">Milestone を選択してください。未選択時は Dashboard / Issues / Gantt のデータは表示されません。</MudAlert>
}
else
{
    <MudTabs @bind-ActivePanelIndex="_activeTabIndex">
        <MudTabPanel Text="Dashboard">
            <MudGrid Class="mb-4 mt-2">
                <MudItem xs="12" sm="6" lg="3">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Total Issues</MudText>
                        <MudText Typo="Typo.h5">@_dashboard?.TotalIssues</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" lg="3">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Open Issues</MudText>
                        <MudText Typo="Typo.h5">@_dashboard?.OpenIssues</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" lg="3">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Closed Issues</MudText>
                        <MudText Typo="Typo.h5">@_dashboard?.ClosedIssues</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" lg="3">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Overdue Issues</MudText>
                        <MudText Typo="Typo.h5">@_dashboard?.OverdueIssues</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Start</MudText>
                        <MudText Typo="Typo.h6">@(_dashboard?.StartDate?.ToString("yyyy-MM-dd") ?? "-")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Due</MudText>
                        <MudText Typo="Typo.h6">@(_dashboard?.DueDate?.ToString("yyyy-MM-dd") ?? "-")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Estimate</MudText>
                        <MudText Typo="Typo.h6">@FormatSeconds(_dashboard?.EstimateSeconds ?? 0)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Actual</MudText>
                        <MudText Typo="Typo.h6">@FormatSeconds(_dashboard?.ActualSeconds ?? 0)</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Class="pa-4 mt-4">
                <MudText Typo="Typo.h6" Class="mb-3">Estimate / Actual by Member</MudText>
                <MudTable Items="_memberWorkloads" Dense="true">
                    <HeaderContent>
                        <MudTh>Member</MudTh>
                        <MudTh>Estimate</MudTh>
                        <MudTh>Actual</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Member">@context.MemberName</MudTd>
                        <MudTd DataLabel="Estimate">@FormatSeconds(context.EstimateSeconds)</MudTd>
                        <MudTd DataLabel="Actual">@FormatSeconds(context.ActualSeconds)</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Issues">
            <MudGrid Class="mb-3">
                <MudItem xs="12" sm="6" md="3">
                    <label class="selector-label" for="issue-state-select">State</label>
                    <select id="issue-state-select"
                            class="selector-input"
                            value="@_issueStateFilter"
                            @onchange="OnIssueStateFilterChanged">
                        <option value="@AllStatesValue">All</option>
                        @foreach (var state in _issueStates)
                        {
                            <option value="@state">@state</option>
                        }
                    </select>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <label class="selector-label" for="issue-assignee-select">Assignee</label>
                    <select id="issue-assignee-select"
                            class="selector-input"
                            value="@_issueAssigneeFilter"
                            @onchange="OnIssueAssigneeFilterChanged">
                        <option value="@AllAssigneesValue">All</option>
                        @foreach (var assignee in _issueAssignees)
                        {
                            <option value="@assignee">@assignee</option>
                        }
                    </select>
                </MudItem>
            </MudGrid>

            <MudTable Items="_filteredIssues">
                <HeaderContent>
                    <MudTh>Id</MudTh>
                    <MudTh>Title</MudTh>
                    <MudTh>Project</MudTh>
                    <MudTh>Assignee</MudTh>
                    <MudTh>State</MudTh>
                    <MudTh>Estimate</MudTh>
                    <MudTh>Actual</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Id">@context.Id</MudTd>
                    <MudTd DataLabel="Title">
                        @if (!string.IsNullOrWhiteSpace(context.IssueUrl))
                        {
                            <MudLink Href="@context.IssueUrl" Target="_blank">@context.Title</MudLink>
                        }
                        else
                        {
                            @context.Title
                        }
                    </MudTd>
                    <MudTd DataLabel="Project">
                        @if (!string.IsNullOrWhiteSpace(context.ProjectUrl))
                        {
                            <MudLink Href="@context.ProjectUrl" Target="_blank">@context.ProjectName</MudLink>
                        }
                        else
                        {
                            @context.ProjectName
                        }
                    </MudTd>
                    <MudTd DataLabel="Assignee">@context.Assignee</MudTd>
                    <MudTd DataLabel="State">@context.State</MudTd>
                    <MudTd DataLabel="Estimate">@FormatIssueDuration(context.HumanTimeEstimate, context.TimeEstimateSeconds)
                    </MudTd>
                    <MudTd DataLabel="Actual">@FormatIssueDuration(context.HumanTotalTimeSpent,
                                            context.TotalTimeSpentSeconds)</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudTabPanel>

            <MudTabPanel Text="Gantt">
                <MudGrid Class="mb-3">
                    <MudItem xs="12" sm="6" md="3">
                        <label class="selector-label" for="gantt-assignee-select">Assignee</label>
                        <select id="gantt-assignee-select"
                                class="selector-input"
                                value="@_ganttAssigneeFilter"
                                @onchange="OnGanttAssigneeFilterChanged">
                            <option value="@AllAssigneesValue">All</option>
                            @foreach (var assignee in _ganttAssignees)
                            {
                                <option value="@assignee">@assignee</option>
                            }
                        </select>
                    </MudItem>
                </MudGrid>

                <MudTable Items="_filteredGanttItems">
                    <HeaderContent>
                        <MudTh>Title</MudTh>
                        <MudTh>Mode</MudTh>
                        <MudTh>Assignee</MudTh>
                        <MudTh>Start</MudTh>
                        <MudTh>End</MudTh>
                        <MudTh>Progress</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Title">@context.Title</MudTd>
                        <MudTd DataLabel="Mode">@context.ViewMode</MudTd>
                        <MudTd DataLabel="Assignee">@context.Assignee</MudTd>
                        <MudTd DataLabel="Start">@context.StartDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd DataLabel="End">@context.EndDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd DataLabel="Progress">
                            <MudProgressLinear Color="Color.Secondary" Value="@context.Progress" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudTabPanel>
        </MudTabs>
    }

@code {
    private bool _isLoading;
    private string? _errorMessage;
    private MilestoneDashboardViewModel? _dashboard;
    private IReadOnlyList<IssueViewModel> _issues = [];
    private IReadOnlyList<GanttItemViewModel> _ganttItems = [];
    private IReadOnlyList<MemberWorkloadViewModel> _memberWorkloads = [];
    private IReadOnlyList<IssueViewModel> _filteredIssues = [];
    private IReadOnlyList<string> _issueStates = [];
    private IReadOnlyList<string> _issueAssignees = [];
    private IReadOnlyList<string> _ganttAssignees = [];
    private IReadOnlyList<GanttItemViewModel> _filteredGanttItems = [];
    private int _activeTabIndex;
    private string _issueStateFilter = AllStatesValue;
    private string _issueAssigneeFilter = AllAssigneesValue;
    private string _ganttAssigneeFilter = AllAssigneesValue;

    private const string AllStatesValue = "__all__";
    private const string AllAssigneesValue = "__all__";

    protected override async Task OnInitializedAsync()
    {
        SelectionState.Changed += OnSelectionChanged;
        await LoadMilestoneDataAsync();
    }

    public void Dispose()
    {
        SelectionState.Changed -= OnSelectionChanged;
    }

    private async void OnSelectionChanged()
    {
        await InvokeAsync(LoadMilestoneDataAsync);
    }

    private async Task LoadMilestoneDataAsync()
    {
        _errorMessage = null;

        if (!SelectionState.HasPrivateToken)
        {
            _dashboard = null;
            _issues = [];
            _ganttItems = [];
            _memberWorkloads = [];
            _filteredIssues = [];
            _issueStates = [];
            _issueAssignees = [];
            _ganttAssignees = [];
            _filteredGanttItems = [];
            _issueStateFilter = AllStatesValue;
            _issueAssigneeFilter = AllAssigneesValue;
            _ganttAssigneeFilter = AllAssigneesValue;
            _isLoading = false;
            StateHasChanged();
            return;
        }

        var milestoneId = SelectionState.SelectedMilestoneId;
        if (!milestoneId.HasValue)
        {
            _dashboard = null;
            _issues = [];
            _ganttItems = [];
            _memberWorkloads = [];
            _filteredIssues = [];
            _issueStates = [];
            _issueAssignees = [];
            _ganttAssignees = [];
            _filteredGanttItems = [];
            _issueStateFilter = AllStatesValue;
            _issueAssigneeFilter = AllAssigneesValue;
            _ganttAssigneeFilter = AllAssigneesValue;
            _isLoading = false;
            StateHasChanged();
            return;
        }

        _isLoading = true;
        StateHasChanged();

        try
        {
            _dashboard = await ApiClient.GetDashboardAsync(milestoneId.Value);
            _issues = await ApiClient.GetIssuesAsync(milestoneId.Value);
            _ganttItems = await ApiClient.GetGanttAsync(milestoneId.Value);
            _memberWorkloads = BuildMemberWorkloads(_issues);
            _issueStates = _issues
                .Select(issue => issue.State)
                .Where(state => !string.IsNullOrWhiteSpace(state))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(state => state, StringComparer.OrdinalIgnoreCase)
                .ToList();
            _issueAssignees = _issues
                .Select(issue => string.IsNullOrWhiteSpace(issue.Assignee) ? "Unassigned" : issue.Assignee)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(assignee => assignee, StringComparer.OrdinalIgnoreCase)
                .ToList();
            _ganttAssignees = _ganttItems
                .Select(item => string.IsNullOrWhiteSpace(item.Assignee) ? "Unassigned" : item.Assignee)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(assignee => assignee, StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (_issueStateFilter != AllStatesValue && !_issueStates.Contains(_issueStateFilter, StringComparer.OrdinalIgnoreCase))
            {
                _issueStateFilter = AllStatesValue;
            }

            if (_issueAssigneeFilter != AllAssigneesValue && !_issueAssignees.Contains(_issueAssigneeFilter, StringComparer.OrdinalIgnoreCase))
            {
                _issueAssigneeFilter = AllAssigneesValue;
            }

            if (_ganttAssigneeFilter != AllAssigneesValue && !_ganttAssignees.Contains(_ganttAssigneeFilter, StringComparer.OrdinalIgnoreCase))
            {
                _ganttAssigneeFilter = AllAssigneesValue;
            }

            ApplyIssueFilter();
            ApplyGanttFilter();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _dashboard = null;
            _issues = [];
            _ganttItems = [];
            _memberWorkloads = [];
            _filteredIssues = [];
            _issueStates = [];
            _issueAssignees = [];
            _ganttAssignees = [];
            _filteredGanttItems = [];
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private static string FormatIssueDuration(string? humanReadable, int seconds)
    {
        if (!string.IsNullOrWhiteSpace(humanReadable))
        {
            return humanReadable;
        }

        return FormatSeconds(seconds);
    }

    private static string FormatSeconds(int seconds)
    {
        if (seconds <= 0)
        {
            return "0m";
        }

        const int secondsPerMinute = 60;
        const int minutesPerHour = 60;
        const int hoursPerDay = 8;
        const int daysPerWeek = 5;

        var totalMinutes = seconds / secondsPerMinute;
        var minutesPerDay = hoursPerDay * minutesPerHour;
        var minutesPerWeek = daysPerWeek * minutesPerDay;

        var weeks = totalMinutes / minutesPerWeek;
        totalMinutes %= minutesPerWeek;

        var days = totalMinutes / minutesPerDay;
        totalMinutes %= minutesPerDay;

        var hours = totalMinutes / minutesPerHour;
        var minutes = totalMinutes % minutesPerHour;

        var parts = new List<string>(4);
        if (weeks > 0)
        {
            parts.Add($"{weeks}w");
        }

        if (days > 0)
        {
            parts.Add($"{days}d");
        }

        if (hours > 0)
        {
            parts.Add($"{hours}h");
        }

        if (minutes > 0)
        {
            parts.Add($"{minutes}m");
        }

        return parts.Count == 0 ? "0m" : string.Join(' ', parts);
    }

    private void OnIssueStateFilterChanged(ChangeEventArgs args)
    {
        _issueStateFilter = args.Value?.ToString() ?? AllStatesValue;
        ApplyIssueFilter();
    }

    private void OnIssueAssigneeFilterChanged(ChangeEventArgs args)
    {
        _issueAssigneeFilter = args.Value?.ToString() ?? AllAssigneesValue;
        ApplyIssueFilter();
    }

    private void OnGanttAssigneeFilterChanged(ChangeEventArgs args)
    {
        _ganttAssigneeFilter = args.Value?.ToString() ?? AllAssigneesValue;
        ApplyGanttFilter();
    }

    private void ApplyIssueFilter()
    {
        _filteredIssues = _issues
            .Where(issue => _issueStateFilter == AllStatesValue ||
                issue.State.Equals(_issueStateFilter, StringComparison.OrdinalIgnoreCase))
            .Where(issue => _issueAssigneeFilter == AllAssigneesValue ||
                NormalizeAssignee(issue.Assignee).Equals(_issueAssigneeFilter, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void ApplyGanttFilter()
    {
        _filteredGanttItems = _ganttItems
            .Where(item => _ganttAssigneeFilter == AllAssigneesValue ||
                NormalizeAssignee(item.Assignee).Equals(_ganttAssigneeFilter, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private static IReadOnlyList<MemberWorkloadViewModel> BuildMemberWorkloads(IReadOnlyList<IssueViewModel> issues)
    {
        return issues
            .GroupBy(issue => NormalizeAssignee(issue.Assignee))
            .Select(group => new MemberWorkloadViewModel(
                group.Key,
                group.Sum(issue => issue.TimeEstimateSeconds),
                group.Sum(issue => issue.TotalTimeSpentSeconds)))
            .OrderByDescending(item => item.EstimateSeconds)
            .ThenBy(item => item.MemberName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string NormalizeAssignee(string? assignee)
        => string.IsNullOrWhiteSpace(assignee) ? "Unassigned" : assignee;

    private sealed record MemberWorkloadViewModel(
        string MemberName,
        int EstimateSeconds,
        int ActualSeconds);
}
